---
import '@fontsource-variable/pontano-sans';
import '@fontsource-variable/eb-garamond';
import '../styles/global.css';

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { address, areaServed, contact, practitioner, site } from '../config/site';

interface Props {
  title: string;
  description?: string;
  /** Set on the homepage only, so the site name isn't duplicated in the tab. */
  bareTitle?: boolean;
}

const { title, description = site.description, bareTitle = false } = Astro.props;

const pageTitle = bareTitle ? title : `${title} — ${site.name}`;
const canonical = new URL(Astro.url.pathname, site.url).href;
const ogImage = new URL('/og-image.jpg', site.url).href;

/**
 * Structured data, built from src/config/site.ts so it cannot drift from the
 * visible page. The Squarespace original advertised a stale Oregon City address
 * and listed Squarespace's own social accounts as this practice's profiles;
 * both are corrected here, and `sameAs` is omitted since there are no profiles.
 */
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': ['LocalBusiness', 'MedicalBusiness'],
      '@id': `${site.url}/#practice`,
      name: site.name,
      url: site.url,
      email: contact.email,
      telephone: contact.phone,
      faxNumber: contact.fax,
      priceRange: '$$',
      address: {
        '@type': 'PostalAddress',
        streetAddress: address.street,
        addressLocality: address.city,
        addressRegion: address.state,
        postalCode: address.zip,
        addressCountry: address.country,
      },
      areaServed: areaServed.map((name) => ({ '@type': 'State', name })),
      founder: { '@id': `${site.url}/#brandon` },
    },
    {
      '@type': 'Person',
      '@id': `${site.url}/#brandon`,
      name: practitioner.name,
      honorificSuffix: practitioner.degree,
      jobTitle: 'Licensed Marriage & Family Therapist',
      email: contact.email,
      telephone: contact.phone,
      worksFor: { '@id': `${site.url}/#practice` },
      hasCredential: practitioner.licenses.map((l) => ({
        '@type': 'EducationalOccupationalCredential',
        credentialCategory: 'license',
        name: `${l.title} (${l.state} #${l.number})`,
      })),
    },
  ],
};
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {/* Brandon's own icon, pulled from the Squarespace site. Squarespace served
        it as JPEG despite the .ico name, hence the extension and type here. */}
    <link rel="icon" href="/favicon.jpg" type="image/jpeg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
  </head>

  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
