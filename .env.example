# Copy to .env for local development. NEVER commit .env — it is gitignored.
# In production these are set in the Cloudflare Pages dashboard under
# Settings > Environment variables, not in this file.

# Resend API key, from https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here

# Where contact form notifications are delivered.
CONTACT_TO=brandon@bjohnsoncounseling.com

# The address the notification is sent FROM. Must be on a domain you've verified
# in Resend (bjohnsoncounseling.com) — not a free mailbox like Gmail.
CONTACT_FROM=contact@bjohnsoncounseling.com

# Optional. Set to enable Cloudflare Turnstile spam verification.
# Leave unset and the form falls back to the honeypot alone.
TURNSTILE_SECRET=
