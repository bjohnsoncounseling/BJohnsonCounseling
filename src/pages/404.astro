---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { nav } from '../config/site';
---

<BaseLayout title="Page Not Found" description="The page you were looking for could not be found.">
  <section class="section">
    <div class="container measure center">
      <p class="code">404</p>
      <h1>This page can’t be found</h1>
      <p>
        The page you were looking for may have moved or no longer exists. Let’s get you
        back on the path.
      </p>
      <p class="cta"><Button href="/">Return home</Button></p>

      <nav class="links" aria-label="Site pages">
        {nav.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
    </div>
  </section>
</BaseLayout>

<style>
  .code {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(3.5rem, 10vw, 6rem);
    line-height: 1;
    color: var(--accent);
  }

  .cta {
    margin-top: var(--space-md);
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs) var(--space-md);
    justify-content: center;
    margin-top: var(--space-lg);
    padding-top: var(--space-md);
    border-top: 1px solid var(--rule);
  }

  .links a {
    color: var(--accent-text);
  }
</style>
