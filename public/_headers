# Cloudflare Pages security headers. Applied to every response.
# https://developers.cloudflare.com/pages/configuration/headers/
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  # 'unsafe-inline' is needed for Astro's inline JSON-LD and the form-status
  # script. The one third-party origin allowed is challenges.cloudflare.com — the
  # contact form's Cloudflare Turnstile widget (its script, its verification
  # XHR via connect-src, and the iframe it renders via frame-src). Everything
  # else stays locked to 'self'. Tighten inline to hashes later via Astro's CSP
  # support if desired.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com; form-action 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; upgrade-insecure-requests
