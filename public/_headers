# Cloudflare Pages security headers. Applied to every response.
# https://developers.cloudflare.com/pages/configuration/headers/
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  # 'unsafe-inline' is needed for Astro's inline JSON-LD and the form-status
  # script; it still blocks scripts/styles/frames from external origins. The site
  # loads no third-party JS, so everything else is locked to 'self'. Tighten to
  # hashes later via Astro's CSP support if desired.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; form-action 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; upgrade-insecure-requests
